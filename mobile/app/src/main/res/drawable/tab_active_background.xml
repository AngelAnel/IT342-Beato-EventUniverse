<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow/shadow layer -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="0dp">
        <shape>
            <solid android:color="#6B1A1A" />
            <corners android:radius="9dp" />
        </shape>
    </item>
    <!-- Main button surface pushed up slightly -->
    <item android:bottom="3dp">
        <shape>
            <solid android:color="#F5F0E8" />
            <corners android:radius="8dp" />
            <stroke android:color="#6B1A1A" android:width="2.5dp" />
        </shape>
    </item>
</layer-list>